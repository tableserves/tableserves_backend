# TableServe Environment Configuration

# API Configuration
VITE_API_BASE_URL=http://localhost:3001/api

# JWT Configuration (Production - Use Strong Random Secrets)
# Generate using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
VITE_JWT_SECRET=your_super_secure_jwt_secret_key_here_64_bytes_minimum
VITE_JWT_REFRESH_SECRET=your_super_secure_refresh_secret_key_here_64_bytes_minimum

# JWE (JSON Web Encryption) Configuration
# For additional security layer to encrypt JWT tokens
# Generate using: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
VITE_JWE_SECRET=your_super_secure_jwe_encryption_key_here_32_bytes
VITE_JWE_IV_SECRET=your_super_secure_jwe_iv_key_here_32_bytes

# JWT Token Configuration
VITE_JWT_ACCESS_EXPIRY=15m
VITE_JWT_REFRESH_EXPIRY=7d

# Token Expiry Options:
# - Use 's' for seconds (e.g., '30s')
# - Use 'm' for minutes (e.g., '15m', '30m', '60m')
# - Use 'h' for hours (e.g., '1h', '2h', '24h')
# - Use 'd' for days (e.g., '1d', '7d', '30d')
#
# Security Recommendations:
# - High Security (Banking): 5m access, 1d refresh
# - Standard Security (Most Apps): 15m access, 7d refresh  
# - Low Security (Internal Tools): 1h access, 30d refresh

# Security Configuration
VITE_ENABLE_JWE=true
VITE_SECURITY_LEVEL=high

# Development Note:
# For production, always generate strong random secrets using the commands above
# Never use the example values in production
# Store these values securely and never commit them to version control